#!/bin/bash
#PBS -N rjg_att133_rnd
#PBS -q auto
#PBS -P CFP03-CF-035
#PBS -l select=1:ncpus=12:ngpus=1:mem=225gb
#PBS -l walltime=12:00:00
#PBS -j oe
#PBS -o /scratch/e1561245/cot_yz/codar_output/codar_rjg_v1/pbs_logs/

set -euo pipefail

PROJECT=/scratch/e1561245/cot_yz/codar_rjg_v1
OUTPUT_ROOT=/scratch/e1561245/cot_yz/codar_output/codar_rjg_v1
BASE=/scratch/e1561245/internvl
VENV_DIR=${BASE}/venv/vllm_ivl35_38b_full_newformat
MODEL_PATH=${BASE}/models/OpenGVLab/InternVL3_5-38B
MODEL_NAME=internvl3_5_38b-local
HOST=127.0.0.1
PORT=8010
RUN_DIR=${OUTPUT_ROOT}/rjg_attitude133_random_opt_${PBS_JOBID}
FULL_INPUT_JSON=${PROJECT}/data/datasetv3.18_hf_319_updatev1.json
INPUT_JSON=${RUN_DIR}/eval_attitude133_random.json
MEMORY_JSON=${RUN_DIR}/rjg_memory_attitude133_random.json
CFG=${PROJECT}/config/runtime.internvl.attitude.opt.yaml
SEED=$(( (10#${PBS_JOBID%%.*} % 1000000) + $(date +%s) % 1000000 ))

mkdir -p "${RUN_DIR}"
mkdir -p "${OUTPUT_ROOT}/pbs_logs"
echo "[INFO] job_id=${PBS_JOBID}" > "${RUN_DIR}/meta.log"
echo "[INFO] run_dir=${RUN_DIR}" >> "${RUN_DIR}/meta.log"
echo "[INFO] start_time=$(date -Iseconds)" >> "${RUN_DIR}/meta.log"
echo "[INFO] random_seed=${SEED}" >> "${RUN_DIR}/meta.log"

source "${VENV_DIR}/bin/activate"
python -m pip install -U pip >/dev/null 2>&1 || true
python -m pip install -e "${PROJECT}" > "${RUN_DIR}/pip_install.log" 2>&1 || {
  echo "[FATAL] pip install -e failed" | tee -a "${RUN_DIR}/meta.log"
  tail -n 200 "${RUN_DIR}/pip_install.log" || true
  exit 1
}

export HF_HOME=${BASE}/models/hf_cache
export HUGGINGFACE_HUB_CACHE=${BASE}/models/hf_cache
export FFMPEG_BIN=${BASE}/tools/ffmpeg_static/bin/ffmpeg
export FFPROBE_BIN=${BASE}/tools/ffmpeg_static/bin/ffprobe

# Keep tokenizer warning fixed even if environment was refreshed.
python - <<'PY' >/dev/null 2>&1 || true
from pathlib import Path
tok_cfg = Path("/scratch/e1561245/internvl/models/OpenGVLab/InternVL3_5-38B/tokenizer_config.json")
if tok_cfg.exists():
    text = tok_cfg.read_text(encoding="utf-8")
    if '"fix_mistral_regex"' not in text:
        if text.rstrip().endswith("}"):
            text = text.rstrip()[:-1] + ',\n  "fix_mistral_regex": true\n}\n'
            tok_cfg.write_text(text, encoding="utf-8")
PY

normalize_cuda_visible_devices() {
  local raw="${CUDA_VISIBLE_DEVICES:-}"
  if [[ -z "${raw}" ]]; then
    return 0
  fi
  if [[ "${raw}" =~ [A-Za-z-] ]]; then
    IFS=',' read -ra _DEV_ARR <<< "${raw}"
    local dev_count="${#_DEV_ARR[@]}"
    if [[ "${dev_count}" -gt 0 ]]; then
      export CUDA_VISIBLE_DEVICES="$(seq -s, 0 $((dev_count - 1)))"
    else
      export CUDA_VISIBLE_DEVICES=0
    fi
  fi
}

normalize_cuda_visible_devices
nvidia-smi > "${RUN_DIR}/nvidia_smi.txt"
echo "[INFO] cuda_visible_devices=${CUDA_VISIBLE_DEVICES:-<unset>}" | tee -a "${RUN_DIR}/meta.log"

start_vllm_server() {
  : > "${RUN_DIR}/vllm_server.log"
  vllm serve "${MODEL_PATH}" \
    --host "${HOST}" \
    --port "${PORT}" \
    --served-model-name "${MODEL_NAME}" \
    --trust-remote-code \
    --dtype float16 \
    --tensor-parallel-size 1 \
    --gpu-memory-utilization 0.95 \
    --max-model-len 32768 \
    --mm-processor-kwargs '{"max_dynamic_patch":6}' \
    --limit-mm-per-prompt '{"image":4}' \
    > "${RUN_DIR}/vllm_server.log" 2>&1 &
  SERVER_PID=$!
}

wait_vllm_ready() {
  for i in $(seq 1 900); do
    if grep -q "CUDA driver initialization failed\|Engine core initialization failed" "${RUN_DIR}/vllm_server.log" 2>/dev/null; then
      return 3
    fi
    if ! kill -0 "${SERVER_PID}" >/dev/null 2>&1; then
      return 2
    fi
    if curl -sf "http://${HOST}:${PORT}/v1/models" > "${RUN_DIR}/vllm_models.json.tmp"; then
      mv "${RUN_DIR}/vllm_models.json.tmp" "${RUN_DIR}/vllm_models.json"
      READY_CODE=$(curl -s -o "${RUN_DIR}/vllm_ready_probe.json" -w '%{http_code}' \
        -X POST "http://${HOST}:${PORT}/v1/chat/completions" \
        -H 'Content-Type: application/json' \
        --data "{\"model\":\"${MODEL_NAME}\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1,\"temperature\":0}" || true)
      if [[ "${READY_CODE}" == "200" ]] && grep -q '"choices"' "${RUN_DIR}/vllm_ready_probe.json"; then
        return 0
      fi
    fi
    sleep 2
  done
  return 1
}

SERVER_PID=""
cleanup(){ kill "${SERVER_PID}" >/dev/null 2>&1 || true; }
trap cleanup EXIT

cd "${PROJECT}"
python scripts/build_random_scenario_subset.py \
  --input-json "${FULL_INPUT_JSON}" \
  --output-json "${INPUT_JSON}" \
  --scenario attitude \
  --size 133 \
  --seed "${SEED}" \
  --report-json "${RUN_DIR}/eval_attitude133_random.report.json" \
  > "${RUN_DIR}/build_subset.log" 2>&1

start_vllm_server
if ! wait_vllm_ready; then
  if grep -q "CUDA driver initialization failed" "${RUN_DIR}/vllm_server.log"; then
    echo "[WARN] detected CUDA init failure; retrying vLLM once with CUDA_VISIBLE_DEVICES=0" | tee -a "${RUN_DIR}/meta.log"
    kill "${SERVER_PID}" >/dev/null 2>&1 || true
    sleep 3
    export CUDA_VISIBLE_DEVICES=0
    echo "[INFO] retry_cuda_visible_devices=${CUDA_VISIBLE_DEVICES}" | tee -a "${RUN_DIR}/meta.log"
    start_vllm_server
    if ! wait_vllm_ready; then
      echo '[FATAL] vLLM retry failed to become ready' >&2
      tail -n 200 "${RUN_DIR}/vllm_server.log" || true
      exit 1
    fi
  else
    echo '[FATAL] vLLM server not ready (no CUDA-init retry condition met)' >&2
    tail -n 200 "${RUN_DIR}/vllm_server.log" || true
    exit 1
  fi
fi

python -m codar.cli build-memory-index \
  --input "${INPUT_JSON}" \
  --out "${MEMORY_JSON}" \
  --scenario attitude \
  > "${RUN_DIR}/build_memory.log" 2>&1

python -m codar.cli run-rjg-batch \
  --input "${INPUT_JSON}" \
  --memory "${MEMORY_JSON}" \
  --output-dir "${RUN_DIR}" \
  --backend vllm \
  --config "${CFG}" \
  --scenario attitude \
  > "${RUN_DIR}/run_rjg.log" 2>&1

python -m codar.cli evaluate \
  --predictions "${RUN_DIR}/predictions.jsonl" \
  --input "${INPUT_JSON}" \
  --output-metrics "${RUN_DIR}/metrics.json" \
  --output-detailed "${RUN_DIR}/metrics.detailed.json" \
  > "${RUN_DIR}/evaluate.log" 2>&1

python -m codar.cli tune-rjg \
  --predictions "${RUN_DIR}/predictions.jsonl" \
  --input "${INPUT_JSON}" \
  --output-dir "${RUN_DIR}/tuned" \
  --search-budget 120 \
  > "${RUN_DIR}/tune_rjg.log" 2>&1

python -m codar.cli evaluate \
  --predictions "${RUN_DIR}/tuned/predictions.tuned.jsonl" \
  --input "${INPUT_JSON}" \
  --output-metrics "${RUN_DIR}/tuned/metrics.eval.json" \
  --output-detailed "${RUN_DIR}/tuned/metrics.eval.detailed.json" \
  > "${RUN_DIR}/evaluate_tuned.log" 2>&1

echo "run_dir=${RUN_DIR}"
echo "[INFO] end_time=$(date -Iseconds)" | tee -a "${RUN_DIR}/meta.log"
