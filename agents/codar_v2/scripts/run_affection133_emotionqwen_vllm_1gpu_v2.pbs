#!/bin/bash
#PBS -N codar_v2_eqwen_aff133
#PBS -q auto
#PBS -P CFP03-CF-035
#PBS -l select=1:ncpus=32:ngpus=1:mem=250gb
#PBS -l walltime=16:00:00
#PBS -j oe
#PBS -o /scratch/e1561245/cot_yz/codar_output/codar_v2/pbs_logs/

set -euo pipefail

PROJECT=/scratch/e1561245/cot_yz/codar_v2
OUTPUT_ROOT=/scratch/e1561245/cot_yz/codar_output/codar_v2
BASE=/scratch/e1561245/internvl
VENV_DIR=${BASE}/venv/vllm_ivl35_38b_full_newformat
MODEL_PATH=${EMOTION_QWEN_MODEL_PATH:-/scratch/users/nus/e1553307/experiment/models/Emotion-Qwen-pretrained}
MODEL_NAME=emotion-qwen-local
HOST=127.0.0.1
PORT=8010
RUN_DIR=${OUTPUT_ROOT}/affection133_emotionqwen_v2_${PBS_JOBID}
FULL_INPUT=${PROJECT}/data/datasetv3.18_hf_319_updatev1.json
FALLBACK_INPUT=/scratch/e1561245/cot_yz/codar_rjg_v1/data/datasetv3.18_hf_319_updatev1.json
SUBSET_JSON=${RUN_DIR}/eval_affection133_random.json

if [[ ! -f "${FULL_INPUT}" ]]; then
  FULL_INPUT="${FALLBACK_INPUT}"
fi

if [[ ! -e "${MODEL_PATH}" ]]; then
  echo "[FATAL] model path not found: ${MODEL_PATH}" >&2
  exit 1
fi

mkdir -p "${RUN_DIR}"
mkdir -p "${OUTPUT_ROOT}/pbs_logs"
source "${VENV_DIR}/bin/activate"
python -m pip install -U pip >/dev/null 2>&1 || true
python -m pip install -U openai >/dev/null 2>&1 || true

export HF_HOME=${BASE}/models/hf_cache
export HUGGINGFACE_HUB_CACHE=${BASE}/models/hf_cache
export FFMPEG_BIN=${BASE}/tools/ffmpeg_static/bin/ffmpeg
export FFPROBE_BIN=${BASE}/tools/ffmpeg_static/bin/ffprobe

if [[ "${CUDA_VISIBLE_DEVICES:-}" == GPU-* ]]; then
  IFS=',' read -ra _DEV_ARR <<< "${CUDA_VISIBLE_DEVICES}"
  LAST_IDX=$(( ${#_DEV_ARR[@]} - 1 ))
  export CUDA_VISIBLE_DEVICES="$(seq -s, 0 "${LAST_IDX}")"
fi

nvidia-smi > "${RUN_DIR}/nvidia_smi.txt"
echo "[INFO] job_id=${PBS_JOBID}" | tee -a "${RUN_DIR}/meta.log"
echo "[INFO] run_dir=${RUN_DIR}" | tee -a "${RUN_DIR}/meta.log"
echo "[INFO] model_path=${MODEL_PATH}" | tee -a "${RUN_DIR}/meta.log"
echo "[INFO] start_time=$(date -Iseconds)" | tee -a "${RUN_DIR}/meta.log"

vllm serve "${MODEL_PATH}" \
  --host "${HOST}" \
  --port "${PORT}" \
  --served-model-name "${MODEL_NAME}" \
  --trust-remote-code \
  --dtype float16 \
  --tensor-parallel-size 1 \
  --gpu-memory-utilization 0.95 \
  --max-model-len 32768 \
  --limit-mm-per-prompt '{"image":8}' \
  > "${RUN_DIR}/vllm_server.log" 2>&1 &
SERVER_PID=$!
cleanup(){ kill ${SERVER_PID} >/dev/null 2>&1 || true; }
trap cleanup EXIT

READY=0
for i in $(seq 1 900); do
  if ! kill -0 ${SERVER_PID} >/dev/null 2>&1; then
    echo '[FATAL] vLLM server exited before ready' >&2
    tail -n 200 "${RUN_DIR}/vllm_server.log" || true
    exit 1
  fi
  if curl -sf "http://${HOST}:${PORT}/v1/models" > "${RUN_DIR}/vllm_models.json.tmp"; then
    mv "${RUN_DIR}/vllm_models.json.tmp" "${RUN_DIR}/vllm_models.json"
    READY_CODE=$(curl -s -o "${RUN_DIR}/vllm_ready_probe.json" -w '%{http_code}' \
      -X POST "http://${HOST}:${PORT}/v1/chat/completions" \
      -H 'Content-Type: application/json' \
      --data "{\"model\":\"${MODEL_NAME}\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1,\"temperature\":0}" || true)
    if [[ "${READY_CODE}" == "200" ]] && grep -q '"choices"' "${RUN_DIR}/vllm_ready_probe.json"; then
      READY=1
      break
    fi
  fi
  sleep 2
done

if [[ ${READY} -ne 1 ]]; then
  echo '[FATAL] vLLM server not ready in timeout' >&2
  tail -n 200 "${RUN_DIR}/vllm_server.log" || true
  exit 1
fi

python "${PROJECT}/scripts/build_random_scenario_subset.py" \
  --input "${FULL_INPUT}" \
  --output "${SUBSET_JSON}" \
  --scenario affection \
  --count 133 > "${RUN_DIR}/subset_build.log" 2>&1

export SILICONFLOW_BASE_URL="http://${HOST}:${PORT}/v1"
export SILICONFLOW_API_KEY="EMPTY"
export INPUT_JSON_PATH="${SUBSET_JSON}"
export OUTPUT_DIR="${RUN_DIR}"
export EVAL_MODEL_NAME="${MODEL_NAME}"
export MAX_WORKERS=8
export SAMPLE_SIZE=0
export SUBJECT_TARGET_PIPELINE_STRATEGY=rjg_role_fusion
export SUBJECT_TARGET_ANCHOR_MIN_CONF=0.55
export SUBJECT_TARGET_ROLE_PROBE_ENABLED=1
export SUBJECT_TARGET_ROLE_PROBE_MIN_CONF=0.55

python "${PROJECT}/nus_evalfin_319_v2.py" \
  --input-json-path "${SUBSET_JSON}" \
  --output-dir "${RUN_DIR}" \
  > "${RUN_DIR}/run_eval.log" 2>&1

echo "run_dir=${RUN_DIR}"
echo "[INFO] end_time=$(date -Iseconds)" | tee -a "${RUN_DIR}/meta.log"
